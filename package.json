{
  "name": "astro-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm run copy-images && npm run copy-newsletter-images && astro dev",
    "build": "npm run copy-images && npm run copy-newsletter-images && astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "test": "node --test scripts/",
    "copy-images": "node scripts/copy-post-images.js",
    "copy-images:force": "node scripts/copy-post-images.js --force",
    "copy-images:clean": "node scripts/copy-post-images.js --clean",
    "images:clean": "node scripts/copy-post-images.js --clean",
    "copy-newsletter-images": "node scripts/copy-newsletter-images.js",
    "copy-newsletter-images:force": "node scripts/copy-newsletter-images.js --force",
    "kit-sync": "node scripts/kit-sync.js",
    "kit-sync:dry-run": "node scripts/kit-sync.js --dry-run",
    "kit-fetch": "node scripts/kit-fetch-sequence.js",
    "kit-fetch:dry-run": "node scripts/kit-fetch-sequence.js --dry-run",
    "kit-add-frontmatter": "node scripts/kit-add-frontmatter.js"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.12",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^5.16.4",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "rehype-raw": "^7.0.0",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-html": "^16.0.1",
    "remark-smartypants": "^3.0.2",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "pagefind": "^1.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "postcss-easy-media-query": "^1.0.0",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.5.0",
    "postcss-text-remove-gap": "^1.1.1",
    "turndown": "^7.2.4"
  }
}
